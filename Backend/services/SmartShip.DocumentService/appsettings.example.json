{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppSettings": {
    "BaseUrl": "http://localhost:5000"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DocumentConnDb": "Server=(localdb)\\MSSQLLocalDB;Database=SmartShipDocumentDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Secret": "__REPLACE_ME__",
    "Issuer": "SmartShip.Auth",
    "Aud1": "SmartShip.Clients",
    "Aud2": "SmartShip.Gateway",
    "Aud3": "SmartShip.IdentityService",
    "Aud4": "SmartShip.AdminService",
    "Aud5": "SmartShip.ShipmentService",
    "Aud6": "SmartShip.TrackingService",
    "Aud7": "SmartShip.DocumentService",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/document-service-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithProperty"]
  }
}
