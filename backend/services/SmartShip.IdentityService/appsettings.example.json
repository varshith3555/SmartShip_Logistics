{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityConnDb": "Server=(localdb)\\MSSQLLocalDB;Database=SmartShipIdentityDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Secret": "__REPLACE_ME__",
    "Issuer": "SmartShip.Auth",
    "Aud1": "SmartShip.Clients",
    "Aud2": "SmartShip.Gateway",
    "Aud3": "SmartShip.IdentityService",
    "Aud4": "SmartShip.AdminService",
    "Aud5": "SmartShip.ShipmentService",
    "Aud6": "SmartShip.TrackingService",
    "Aud7": "SmartShip.DocumentService",
    "ExpiryMinutes": 60
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "Port": 587,
    "SenderEmail": "__REPLACE_ME__",
    "SenderPassword": "__REPLACE_ME__",
    "EnableSsl": true
  },
  "GoogleOAuth": {
    "ClientId": "__REPLACE_ME__",
    "ClientSecret": "__REPLACE_ME__",
    "PublicBaseUrl": "http://localhost:7271",
    "FrontendRedirectUrl": "http://localhost:4200/auth/oauth-callback"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/identity-service-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithProperty"]
  }
}
